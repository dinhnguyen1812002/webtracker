# Uptime Monitor Configuration
# Copy this file to .env and customize the values

# Server Configuration
PORT=8080

# Database Configuration
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Redis Configuration
REDIS_PORT=6380

# Alert Configuration (Optional - set these to enable alerts)
# Telegram Bot (uncomment and set values to enable)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email/SMTP (uncomment and set values to enable)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_ADDRESS=your_email@gmail.com

# Webhook (uncomment and set values to enable)
# WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
https://nhentai.net/
# Worker Configuration
WORKER_POOL_SIZE=10

# Logging Configuration
LOG_LEVEL=info